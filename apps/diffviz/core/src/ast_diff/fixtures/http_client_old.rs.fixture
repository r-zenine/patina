use std::collections::HashMap;
use std::fmt;

pub fn get(&mut self, path: &str) -> Result<String, HttpError> {
    let url = format!("{}/{}", self.config.base_url, path);
    self.make_request("GET", &url, None)
}

#[derive(Debug)]
pub enum HttpError {
    NetworkError(String),
    ParseError(String),
}