{
  "name": "rust_string_literal_content_change",
  "language": "rust",
  "description": "Test detection of string literal content changes in Rust code",
  "category": "content_changes",
  "old_code": "fn main() { println!(\"Hello, World!\"); }",
  "new_code": "fn main() { println!(\"Hello, Universe!\"); }",
  "expected_changes": [
    {
      "change_type": "ContentChange",
      "node_kind": "string_literal",
      "detected_by_strategies": ["byte_range"],
      "description": "String literal content changed from 'Hello, World!' to 'Hello, Universe!'"
    }
  ],
  "should_not_detect": ["child_order", "child_set"],
  "expected_boundary": {
    "node_type": "function_item",
    "content": "fn main() { println!(\"Hello, Universe!\"); }"
  },
  "expected_essential_nodes": [
    {
      "node_type": "function_item",
      "content": "fn main() { println!(\"Hello, Universe!\"); }"
    },
    {
      "node_type": "block", 
      "content": "{ println!(\"Hello, Universe!\"); }"
    },
    {
      "node_type": "expression_statement",
      "content": "println!(\"Hello, Universe!\");"
    },
    {
      "node_type": "macro_invocation",
      "content": "println!(\"Hello, Universe!\")"
    },
    {
      "node_type": "token_tree",
      "content": "(\"Hello, Universe!\")"
    },
    {
      "node_type": "string_literal", 
      "content": "\"Hello, Universe!\""
    }
  ],
  "performance_expectations": {
    "max_duration_ms": 100
  },
  "metadata": {
    "author": "Claude",
    "complexity_level": "simple",
    "tags": ["string_literal", "content_change", "basic"]
  }
}
