{
  "name": "go_operator_change",
  "language": "go",
  "description": "Test detection of binary operator changes",
  "category": "content_changes",
  "old_code": "func calculate(a, b int) int {\n\treturn a + b\n}",
  "new_code": "func calculate(a, b int) int {\n\treturn a * b\n}",
  "expected_changes": [
    {
      "change_type": "ContentChange",
