      "description": "Binary operator changed from '+' to '*'"
    }
  ],
  "should_not_detect": ["child_order", "structural"],
  "performance_expectations": {
    "max_duration_ms": 90
  },
  "metadata": {
    "author": "Claude",
    "complexity_level": "simple",
    "tags": ["operator", "binary", "arithmetic", "content_change"]
  }
}